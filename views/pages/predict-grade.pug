extends ../layouts/default.pug
include ../mixins/checkbox.pug

block title 
  title Dự đoán điểm

block main
  .box-title Dự đoán điểm

  //- Section 4
  .section-4 
    .inner-wrap 
      .inner-item 
        <i class="fa-solid fa-filter"></i>
        | Bộ lọc
      .inner-item
        select(name="")
          option(value="") MSSV
          option(value="") 3122411001
          option(value="") 3122411002
      .inner-item 
        select(name="")
          option(value="") Lớp
          option(value="") DCT122C1
          option(value="") DCT122C2
      .inner-item 
        select(name="")
          option(value="") Khoa
          option(value="") Công nghệ thông tin
          option(value="") Điện tử viễn thông
          option(value="") Sư phạm Anh
      .inner-item 
        select(name="")
          option(value="") Khoá
          option(value="") K22
          option(value="") K23 
          option(value="") K24
      .inner-item.inner-reset
        <i class="fa-solid fa-rotate-left"></i>
        | Xóa bộ lọc
  //- End Section 4

  //- Section 8
  .section-8
    .inner-wrap
      form.inner-search 
        button <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm MSSV/Tên sinh viên")

  //- End Section 8

  //- Section 9
  .section-9 
    .inner-left
      .inner-image 
        img(src="assets/images/avatar-1.jpg", alt="")
      .inner-info
        .inner-name Ronaldo
        .inner-id 3122411001
        .inner-class DCT122C1
        .inner-major Công nghệ thông tin
  //- End Section 9

  //- Section 5
  .section-3
    .table-2 
      table
        thead 
          tr 
            th Mã môn học
            th Tên môn học
            th Số tín chỉ
            th Trạng thái
            th Phân tích & Dự đoán
        tbody 
          tr 
            td MMH001
            td Nhập môn công nghệ thông tin
            td 4
            td 
              .tag.tag-green Đã đăng ký
            td 
              .box-actions 
                a(href="#" class="inner-detail") Xem chi tiết
  //- End Section 5

  //- Section 6
  .section-6 
    button.inner-report 
      <i class="fa-solid fa-download"></i>
      | Lưu kết quả dự đoán
  //- End Section 6

  //- Section-7 
  .section-7 
    .inner-text Hiển thị 1 - 1 của 1
    select
      option(value="") Trang 1
      option(value="") Trang 2
      option(value="") Trang 3
  //- End Section-7

  

