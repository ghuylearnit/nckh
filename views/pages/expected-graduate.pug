extends ../layouts/default.pug
include ../mixins/checkbox.pug

block title 
  title Dự kiến tốt nghiệp

block main
  .box-title Dự kiến tốt nghiệp

  //- Section 4
  .section-4 
    .inner-wrap 
      .inner-item 
        <i class="fa-solid fa-filter"></i>
        | Bộ lọc
      .inner-item
        select(name="")
          option(value="") MSSV
          option(value="") 3122411001
          option(value="") 3122411002
      .inner-item 
        select(name="")
          option(value="") Lớp
          option(value="") DCT122C1
          option(value="") DCT122C2
      .inner-item 
        select(name="")
          option(value="") Khoa
          option(value="") Công nghệ thông tin
          option(value="") Điện tử viễn thông
          option(value="") Sư phạm Anh
      .inner-item 
        select(name="")
          option(value="") Khoá
          option(value="") K22
          option(value="") K23 
          option(value="") K24
      .inner-item.inner-reset
        <i class="fa-solid fa-rotate-left"></i>
        | Xóa bộ lọc
  //- End Section 4

  //- Section 8
  .section-8
    .inner-wrap 
      form.inner-change-status 
        select(name="")
          option(value="") Tất cả
          option(value="") Đúng hạn
          option(value="") Nguy cơ trễ tiến độ
          option(value="") Tốt nghiệp sớm
          option(value="") Chưa đủ điều kiện tốt nghiệp
        button Áp dụng
      form.inner-search 
        button <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm MSSV/Tên sinh viên")

  //- End Section 8

  //- Section 5
  .section-3
    .table-2 
      table
        thead 
          tr 
            th 
            th MSSV
            th Họ tên
            th Lớp
            th Tiến độ tín chỉ
            th GPA hiện tại
            th Học kỳ dự kiến TN
            th Trạng thái
            th Độ tin cậy
            th Hành động
        tbody 
          tr 
            td
              +checkbox-28("checkbox1", "")
            td 3122411001
            td Ronaldo
            td DCT122C1
            td 105/120
            td 2.8 
            td HK2 - 2027
            td 
              .tag.tag-red Nguy cơ trễ tiến độ
            td 85%
            td 
              .box-actions 
                a(href="#" class="inner-distance") Xem lộ trình

  //- End Section 5

  //- Section 6
  .section-6 
    button.inner-report 
      <i class="fa-solid fa-arrow-right-from-bracket"></i>
      | Gửi cảnh báo 
  //- End Section 6

  //- Section-7 
  .section-7 
    .inner-text Hiển thị 1 - 1 của 1
    select
      option(value="") Trang 1
      option(value="") Trang 2
      option(value="") Trang 3
  //- End Section-7

